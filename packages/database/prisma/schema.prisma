datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  MANAGER
  AUTHENTICATED
}

model User {
  id        String   @id @default(uuid())
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  email     String   @unique
  username  String   @unique
  password  String
  role      Role     @default(AUTHENTICATED)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model CmsPage {
  id        String   @id @default(uuid())
  slug      String   @unique
  title     String
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("cms_pages")
}

model Live {
  id           String   @id @default(uuid())
  label        String   @default("PRÓXIMA ETAPA DO PIPELINE")
  title        String
  description  String
  buttonText   String   @default("Entrar na Live") @map("button_text")
  buttonUrl    String   @default("#") @map("button_url")
  thumbnailUrl String?  @map("thumbnail_url")
  isLive       Boolean  @default(false) @map("is_live")
  viewersCount String   @default("0") @map("viewers_count")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("lives")
}

model Episode {
  id        String   @id @default(uuid())
  module    String
  title     String
  duration  String
  imageUrl  String?  @map("image_url")
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("episodes")
}
