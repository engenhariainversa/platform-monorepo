datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ── Roles ────────────────────────────────────────────

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  label       String
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  isAdmin     Boolean  @default(false) @map("is_admin")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users       User[]
  permissions Permission[]

  @@map("roles")
}

// ── Users ────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  email     String   @unique
  username  String   @unique
  password  String
  roleId    String   @map("role_id")
  role      Role     @relation(fields: [roleId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

// ── Permissions ──────────────────────────────────────

model Permission {
  id       String @id @default(uuid())
  resource String
  action   String
  roleId   String @map("role_id")
  role     Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([resource, action, roleId])
  @@map("permissions")
}

model PublicResource {
  id       String @id @default(uuid())
  resource String @unique

  @@map("public_resources")
}

// ── CMS Content ──────────────────────────────────────

model CmsPage {
  id        String   @id @default(uuid())
  slug      String   @unique
  title     String
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("cms_pages")
}

model Live {
  id           String   @id @default(uuid())
  label        String   @default("PRÓXIMA ETAPA DO PIPELINE")
  title        String
  description  String
  buttonText   String   @default("Entrar na Live") @map("button_text")
  // CTA label shown before the event starts (after start, `buttonText` is used).
  buttonTextBefore String @default("Ativar lembrete") @map("button_text_before")
  buttonUrl    String   @default("#") @map("button_url")
  thumbnailUrl String?  @map("thumbnail_url")
  isLive       Boolean  @default(false) @map("is_live")
  viewersCount String   @default("0") @map("viewers_count")
  // Absolute UTC instant the live event starts. The landing derives its "live"
  // status from this: the badge shows once `occursAt` is in the past.
  occursAt     DateTime? @map("occurs_at")
  // IANA timezone (e.g. "America/Sao_Paulo") the admin picked the date/time in.
  // Kept only so the CMS can re-render the local wall-clock time when editing.
  occursAtTimezone String? @map("occurs_at_timezone")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("lives")
}

model Episode {
  id        String   @id @default(uuid())
  module    String
  title     String
  duration  String
  imageUrl  String?  @map("image_url")
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("episodes")
}

// Hero section at the top of the landing page. Singleton, like Live: at most
// one row, edited from the "Hero Section" content CMS page.
model HeroSection {
  id         String   @id @default(uuid())
  title      String   @default("Construindo a maior escola mobile do zero")
  subtitle   String   @default("Acompanhe os bastidores técnicos reais através da nossa jornada Build in Public no YouTube. Aprenda engenharia de software de verdade, vendo como as coisas são feitas na prática.")
  buttonText String   @default("Acompanhar no YouTube") @map("button_text")
  buttonUrl  String   @default("#") @map("button_url")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("hero_section")
}

// "A Escola do Futuro" about section on the landing. Singleton, like Live: at
// most one row, edited from the "About Section" content CMS page. The body is
// stored as plain text; blank lines separate paragraphs when rendered. The two
// stat cards are a fixed pair (value + label each).
model AboutSection {
  id         String   @id @default(uuid())
  title      String   @default("A Escola do Futuro")
  body       String
  stat1Value String   @default("100+") @map("stat1_value")
  stat1Label String   @default("Horas de Live") @map("stat1_label")
  stat2Value String   @default("15k") @map("stat2_value")
  stat2Label String   @default("Devs Ativos") @map("stat2_label")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("about_section")
}

// CTA rendered under the episodes list on the landing ("Ver todos episódios").
// Singleton, like Live: at most one row, edited from the episodes CMS page.
model EpisodesButton {
  id        String   @id @default(uuid())
  text      String   @default("Ver todos episódios")
  url       String   @default("#")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("episodes_button")
}
