# ============================================================
# Dev defaults — safe to commit, used by docker-compose.dev.yml
# Copy to .env for local development:  cp .env.example .env
# ============================================================

# Database (matches docker-compose.dev.yml credentials)
POSTGRES_USER=engenharia
POSTGRES_PASSWORD=inversa_dev_2024
POSTGRES_DB=engenhariainversa
DATABASE_URL=postgresql://engenharia:inversa_dev_2024@localhost:5433/engenhariainversa

# Auth — DO NOT use this secret in production
JWT_SECRET=ei-dev-secret-change-in-production-2024

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4050/graphql

# ============================================================
# Production
# ------------------------------------------------------------
# These must NEVER be committed. In production they are injected
# by GitHub Actions from repository secrets and written into a
# .env file on the deploy target before `docker compose up`.
#
# Required GitHub Actions secrets:
#   - POSTGRES_USER
#   - POSTGRES_PASSWORD       (strong, generated)
#   - POSTGRES_DB
#   - DATABASE_URL            (must point at the `db` service host)
#   - JWT_SECRET              (strong, generated — `openssl rand -hex 64`)
#   - NEXT_PUBLIC_API_URL     (public API URL baked into CMS bundle)
# ============================================================
